graph LR
    %% Definição do Pool / Raias utilizando Subgraphs
    subgraph Pool
        
        subgraph Estudante [Estudante]
            Start((Start)) --> A[1. Acessar Sistema]
            A --> B[2. Selecionar Atividade]
            B --> C{3. Prazo de<br>Entrega<br>Válido?}
            
            C -- Sim --> D[4. Anexar Arquivo]
            D --> E[5. Confirmar Envio]
            E --> End1(((End)))
            
            C -- Não --> F[2.1 Exibir mensagem<br>Prazo encerrado]
            F --> End2((End))
        end

        subgraph Sistema [Sistema]
            G[6. Validar anexo<br>e registrar<br>informações] --> H[7. Salvar dados no<br>banco de dados<br>Data e Hora]
            H --> I[8. Enviar notificação<br>ao professor]
            I --> End3(((End)))
        end
        
    end

    %% Conectores entre as raias (Estudante para Sistema)
    End1 -. Transmite<br>dados/arquivo .-> G

    %% Estilização para melhorar o visual no GitHub
    style Estudante fill:none,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
    style Sistema fill:none,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
    style Pool fill:none,stroke:#333,stroke-width:2px
